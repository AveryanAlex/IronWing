{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for main window",
  "windows": ["main"],
  "platforms": ["linux", "macOS", "windows"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "blec:default",
    "opener:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://autotest.ardupilot.org/Parameters/*" },
        { "url": "https://firmware.ardupilot.org/*" },
        { "url": "https://s3.amazonaws.com/elevation-tiles-prod/*" }
      ]
    }
  ]
}
