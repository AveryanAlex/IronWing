{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "types": ["vite/client", "geojson"],
    "paths": {
      "@platform/core": ["./src/platform/tauri/core.ts"],
      "@platform/event": ["./src/platform/tauri/event.ts"],
      "@platform/http": ["./src/platform/tauri/http.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "vite.config.ts"],
  "exclude": [
    "src/**/*.tsx",
    "src/**/*.jsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/components/**/*",
    "src/hooks/**/*",
    "src/test/**/*",
    "src/lib/configuration-facts.ts",
    "src-old/**/*"
  ]
}
