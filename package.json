{
  "name": "ironwing",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "remote-ui": "node scripts/remote-ui.mjs",
    "frontend:dev": "vite",
    "build": "tsc --noEmit && vite build",
    "demo:dev": "node scripts/demo-dev.mjs",
    "demo:build": "node scripts/demo-build.mjs",
    "typecheck": "tsc --noEmit",
    "frontend:typecheck": "tsc --noEmit",
    "frontend:check": "svelte-check --tsconfig ./tsconfig.json",
    "frontend:build": "tsc --noEmit && vite build",
    "frontend:format": "biome format --write .",
    "frontend:format:check": "biome check .",
    "rust:check": "cargo check --workspace",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "android:dev": "tauri android dev",
    "android:build": "tauri android build --apk",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "node scripts/e2e-run.mjs e2e/smoke.spec.ts e2e/connect-telemetry.spec.ts e2e/logs-workspace.spec.ts e2e/parameter-workspace.spec.ts e2e/setup-workspace.spec.ts e2e/settings-actions.spec.ts e2e/responsive-shell.spec.ts e2e/invalid-udp-bind.spec.ts e2e/wrong-port-cancel.spec.ts",
    "e2e:headed": "node scripts/e2e-run.mjs --headed e2e/smoke.spec.ts e2e/connect-telemetry.spec.ts e2e/logs-workspace.spec.ts e2e/parameter-workspace.spec.ts e2e/setup-workspace.spec.ts e2e/settings-actions.spec.ts e2e/responsive-shell.spec.ts e2e/invalid-udp-bind.spec.ts e2e/wrong-port-cancel.spec.ts",
    "e2e:demo": "VITE_IRONWING_MOCK_PROFILE=demo node scripts/e2e-run.mjs e2e/demo-simulator.spec.ts",
    "e2e:native": "node scripts/e2e-native.mjs"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-geolocation": "^2.3.2",
    "@tauri-apps/plugin-http": "^2.3.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "fflate": "^0.8.2",
    "lucide-svelte": "^1.0.1",
    "maplibre-gl": "^5.3.0",
    "svelte": "^5.55.1",
    "svelte-sonner": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.0",
    "uplot": "^1.6.32"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@playwright/test": "^1.58.2",
    "@sveltejs/vite-plugin-svelte": "6.2.4",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^25.3.0",
    "@wdio/cli": "^9.25.0",
    "@wdio/local-runner": "^9.25.0",
    "@wdio/mocha-framework": "^9.25.0",
    "@wdio/spec-reporter": "^9.25.0",
    "jsdom": "^28.1.0",
    "svelte-check": "^4.4.6",
    "typescript": "^5.6.3",
    "vite": "^7.3.2",
    "vitest": "^4.0.18"
  }
}
