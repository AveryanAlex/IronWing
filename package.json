{
  "name": "ironwing",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "format": "pnpm run format:frontend && pnpm run format:rust",
    "format:frontend": "biome format --write .",
    "format:rust": "cargo fmt --all",
    "check": "pnpm run check:frontend && pnpm run check:rust",
    "check:frontend": "pnpm run check:frontend:format && pnpm run check:frontend:types && pnpm run check:frontend:svelte",
    "check:frontend:format": "biome check .",
    "check:frontend:types": "tsc --noEmit",
    "check:frontend:svelte": "svelte-check --tsconfig ./tsconfig.json",
    "check:rust": "pnpm run check:rust:format && pnpm run check:rust:cargo && pnpm run check:rust:clippy",
    "check:rust:format": "cargo fmt --all -- --check",
    "check:rust:cargo": "cargo check --workspace",
    "check:rust:clippy": "cargo clippy --all-targets --all-features -- -D warnings",
    "test": "pnpm run test:frontend && pnpm run test:rust",
    "test:frontend": "vitest run",
    "test:frontend:watch": "vitest",
    "test:rust": "cargo test --workspace",
    "e2e": "pnpm run e2e:browser && pnpm run e2e:browser:demo && pnpm run e2e:native",
    "e2e:browser": "node scripts/e2e-run.mjs",
    "e2e:browser:headed": "node scripts/e2e-run.mjs --headed",
    "e2e:browser:demo": "node scripts/e2e-run.mjs --mock-profile demo e2e/demo-simulator.spec.ts",
    "e2e:native": "node scripts/e2e-native.mjs",
    "dev:desktop": "node scripts/dev.mjs",
    "dev:desktop:remote": "node scripts/remote-ui.mjs",
    "dev:android": "node scripts/android-dev.mjs",
    "dev:web": "node scripts/web-dev.mjs",
    "dev:demo": "node scripts/demo-dev.mjs",
    "build:frontend": "pnpm run check:frontend:types && vite build",
    "build:desktop": "node scripts/desktop-build.mjs",
    "build:android": "node scripts/android-build.mjs",
    "build:web": "node scripts/web-build.mjs",
    "build:demo": "node scripts/demo-build.mjs",
    "internal:wasm:web:debug": "node scripts/wasm-web-build.mjs --dev",
    "internal:wasm:web:release": "node scripts/wasm-web-build.mjs --release",
    "internal:wasm:web:cleanup": "node scripts/wasm-web-build.mjs --cleanup-only",
    "tool:demo:param-fixtures": "node scripts/generate-demo-param-fixtures.mjs",
    "tool:sitl:ws": "node scripts/sitl-ws.mjs"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-geolocation": "^2.3.2",
    "@tauri-apps/plugin-http": "^2.3.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "fflate": "^0.8.2",
    "lucide-svelte": "^1.0.1",
    "maplibre-gl": "^5.3.0",
    "svelte": "^5.55.1",
    "svelte-sonner": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.0",
    "uplot": "^1.6.32"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@playwright/test": "^1.58.2",
    "@sveltejs/vite-plugin-svelte": "6.2.4",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^25.3.0",
    "@wdio/cli": "^9.25.0",
    "@wdio/local-runner": "^9.25.0",
    "@wdio/mocha-framework": "^9.25.0",
    "@wdio/spec-reporter": "^9.25.0",
    "jsdom": "^28.1.0",
    "svelte-check": "^4.4.6",
    "typescript": "^5.6.3",
    "vite": "^7.3.2",
    "vitest": "^4.0.18",
    "ws": "^8.18.3"
  }
}
